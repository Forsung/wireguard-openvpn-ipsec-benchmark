client
dev tun
proto udp

remote <SERVER_IP>

resolv-retry infinite
nobind

persist-key
persist-tun

cipher AES-256-GCM

verb 3

# --- CA certificate ---
<ca>
-----BEGIN CERTIFICATE-----
<certificate in here>
-----END CERTIFICATE-----
</ca>

# --- Client certificate ---
<cert>
-----BEGIN CERTIFICATE-----
<certificate in here>
-----END CERTIFICATE-----
</cert>

# --- Client private key ---
<key>
-----BEGIN PRIVATE KEY-----
<certificate in here>
-----END PRIVATE KEY-----
</key>
